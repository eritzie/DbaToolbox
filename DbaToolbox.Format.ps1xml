    <!-- Get-WaitStatistic (cumulative) -->
    <View>
      <Name>DbaToolbox.WaitStatistic</Name>
      <ViewSelectedBy>
        <TypeName>DbaToolbox.WaitStatistic</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>SqlInstance</Label><Width>25</Width></TableColumnHeader>
          <TableColumnHeader><Label>WaitType</Label><Width>30</Width></TableColumnHeader>
