              <TableColumnItem><PropertyName>LoginName</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
    </View>

    <!-- Get-TempdbConfig (best practice) -->
    <View>
      <Name>DbaToolbox.TempdbBestPractice</Name>
      <ViewSelectedBy>
        <TypeName>DbaToolbox.TempdbBestPractice</TypeName>
      </ViewSelectedBy>
      <TableControl>
        <TableHeaders>
          <TableColumnHeader><Label>SqlInstance</Label><Width>25</Width></TableColumnHeader>
          <TableColumnHeader><Label>Rule</Label><Width>35</Width></TableColumnHeader>
          <TableColumnHeader><Label>CurrentSetting</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>Recommended</Label><Width>20</Width></TableColumnHeader>
          <TableColumnHeader><Label>IsBestPractice</Label><Width>14</Width></TableColumnHeader>
        </TableHeaders>
        <TableRowEntries>
          <TableRowEntry>
            <TableColumnItems>
              <TableColumnItem><PropertyName>SqlInstance</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Rule</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>CurrentSetting</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>Recommended</PropertyName></TableColumnItem>
              <TableColumnItem><PropertyName>IsBestPractice</PropertyName></TableColumnItem>
            </TableColumnItems>
          </TableRowEntry>
        </TableRowEntries>
      </TableControl>
